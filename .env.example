# Copy this file to .env and fill in real values before running docker-compose.prod.yml

# Django secret key — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL
POSTGRES_DB=wagtail
POSTGRES_USER=wagtail
POSTGRES_PASSWORD=change-me-to-secure-password

# Comma-separated list of hostnames the backend will answer on
# e.g. api.yourdomain.com,localhost
DJANGO_ALLOWED_HOSTS=localhost

# Comma-separated list of frontend origins allowed to call the API (CORS)
# e.g. https://yourdomain.com,https://civilia.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Comma-separated trusted origins for CSRF (must include scheme + host)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Full URL of the backend, shown in Wagtail admin emails and "Go live" buttons
WAGTAILADMIN_BASE_URL=http://localhost:8000

# Set to "true" when serving over HTTPS to enable secure cookies
HTTPS_ENABLED=false

# Gunicorn tuning (optional — defaults shown)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
