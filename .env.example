# ─── DEV MODE ────────────────────────────────────────────────────────────────
# Used with docker-compose.dev.yml (SQLite, DEBUG=True, no secrets needed)
# Dev settings are hardcoded in admindashboard/backend/settings/dev.py
# No .env file is needed to run dev mode — just run:
#
#   docker compose -f docker-compose.dev.yml up --build
#
# Then open http://localhost:8000/admin/
# Create a superuser on first run:
#   docker compose -f docker-compose.dev.yml exec backend python manage.py createsuperuser
#
# Both frontend projects at localhost:3000 and localhost:3002 are already
# allowed in CORS (configured in backend/settings/base.py).
# Point them at the backend by setting in each frontend project:
#   NEXT_PUBLIC_WAGTAIL_API_URL=http://localhost:8000/api/v2


# ─── PRODUCTION MODE ─────────────────────────────────────────────────────────
# Copy this block to a .env file and fill in real values, then run:
#
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build

DJANGO_SECRET_KEY=change-me-generate-with-get_random_secret_key
POSTGRES_DB=wagtail
POSTGRES_USER=wagtail
POSTGRES_PASSWORD=change-me-strong-password
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-domain.com
CORS_ALLOWED_ORIGINS=https://your-site-a.com,https://your-site-b.com
CSRF_TRUSTED_ORIGINS=https://your-backend-domain.com
WAGTAILADMIN_BASE_URL=https://your-backend-domain.com
HTTPS_ENABLED=true
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
